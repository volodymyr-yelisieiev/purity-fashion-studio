NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3000
NEXT_PUBLIC_INDEXING_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GA4_ID=
CONTENT_SOURCE=seed
PAYLOAD_ENABLED=false
ALLOW_CMS_SEED=false

# Required to use /admin, Payload Local API, migrations, or CONTENT_SOURCE=payload.
PAYLOAD_SECRET=replace-with-at-least-32-random-characters
PREVIEW_SECRET=replace-with-a-different-32-character-random-token
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/purity

# Optional in local development. All values are required together in production.
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Required when PAYLOAD_ENABLED=true. Use an environment-safe recipient in local/preview.
RESEND_API_KEY=
EMAIL_FROM=studio@example.com
EMAIL_OVERRIDE_RECIPIENT=
SENTRY_DSN=
CRON_SECRET=

PAYMENT_MODE=test
# Required only when PAYMENT_MODE=live.
PAYMENT_MERCHANT_READY=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
