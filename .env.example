# Public client-safe configuration (`VITE_*` only)
VITE_APP_ENV=development
# Keep admin disabled in production until real auth/provider credentials are configured.
VITE_ENABLE_ROUTER_DEVTOOLS=true
VITE_ENABLE_ADMIN=true
VITE_ENABLE_PROTOTYPE_FLOWS=true
VITE_ENABLE_FORCE_MOCK_FAILURES=false
VITE_ANALYTICS_MODE=console

# Server-only configuration (do not expose with `VITE_*`)
APP_ENV=development
ANALYTICS_WRITE_KEY=
# Required when APP_ENV=production; local development falls back to the mock submission adapter.
CONTACT_WEBHOOK_URL=

# Required for production admin access and content writes.
# Local development may use the fallback login `admin` / `purity-local-admin` when these are empty.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Legacy single-token login fallback; prefer ADMIN_USERNAME + ADMIN_PASSWORD.
ADMIN_TOKEN=
ADMIN_SESSION_SECRET=
# Optional JSON overlay file for staging/local editable content.
CONTENT_STORE_PATH=
