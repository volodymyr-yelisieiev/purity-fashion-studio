# Public client-safe configuration (`VITE_*` only)
VITE_APP_ENV=development
# Enable these in local/staging. Keep prototype/dev tooling disabled in production.
VITE_ENABLE_ROUTER_DEVTOOLS=false
VITE_ENABLE_ADMIN=true
VITE_ENABLE_PROTOTYPE_FLOWS=true
VITE_ENABLE_FORCE_MOCK_FAILURES=false
VITE_ANALYTICS_MODE=console

# Server-only configuration (do not expose with `VITE_*`)
APP_ENV=development
ANALYTICS_WRITE_KEY=
# Required when APP_ENV=production; local development falls back to the mock submission adapter.
CONTACT_WEBHOOK_URL=
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Required for production admin access. Use Vercel project/team env vars, never commit real values.
# Local development may use the fallback login `admin` / `purity-local-admin` when these are empty,
# or a private `.env.local` with generated credentials.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Legacy single-token login fallback; prefer ADMIN_USERNAME + ADMIN_PASSWORD.
ADMIN_TOKEN=
ADMIN_SESSION_SECRET=
# Optional JSON overlay file for local/staging editable content. Do not rely on this as durable
# production storage on serverless Vercel; use a CMS/database/blob-backed provider for production.
CONTENT_STORE_PATH=
