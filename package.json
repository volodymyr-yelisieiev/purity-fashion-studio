{
  "name": "purity-fashion-studio",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "setup": "tsx scripts/setup-project.ts",
    "lint": "eslint --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "env:check": "tsx scripts/check-env.ts",
    "content:validate": "tsx scripts/validate-content.ts",
    "cms:check": "tsx scripts/check-cms-contract.ts",
    "cms:seed": "tsx scripts/export-cms-seed.ts",
    "cms:import": "tsx payload/seed/import-seed.ts",
    "payload": "payload",
    "payload:types": "payload generate:types",
    "payload:importmap": "payload generate:importmap",
    "payload:migrate": "payload migrate",
    "payload:migrate:create": "payload migrate:create",
    "payload:migrate:status": "payload migrate:status",
    "payment:check": "tsx scripts/check-payment-contract.ts",
    "qa:static": "tsx scripts/check-qa.ts",
    "qa:budget": "tsx scripts/check-performance-budget.ts",
    "qa:architecture": "tsx scripts/check-architecture.ts",
    "handoff:check": "tsx scripts/check-launch-handoff.ts",
    "test:e2e": "pnpm build && playwright test",
    "qa:all": "pnpm readiness:mvp && pnpm qa:architecture && pnpm test:e2e && pnpm qa:budget",
    "i18n:check": "tsx scripts/check-i18n.ts",
    "tokens:check": "tsx scripts/check-design-tokens.ts",
    "brand:check": "tsx scripts/check-brand-assets.ts",
    "readiness:mvp": "pnpm env:check && pnpm typecheck && pnpm lint && pnpm content:validate && pnpm cms:check && pnpm payment:check && pnpm qa:static && pnpm handoff:check && pnpm i18n:check && pnpm tokens:check && pnpm brand:check"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@next/env": "^16.2.10",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/email-resend": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-redirects": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-vercel-blob": "3.86.0",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "payload": "3.86.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.13.0",
    "sharp": "0.34.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "dompurify": "3.4.11",
      "postcss": ">=8.5.10"
    }
  }
}
