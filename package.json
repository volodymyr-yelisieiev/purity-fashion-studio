{
  "name": "purity-fashion-studio",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "ci:build": "npm run typecheck && npm run test && npm run build",
    "ci:smoke": "node scripts/ci-local.mjs --smoke-only",
    "ci:visual": "node scripts/ci-local.mjs --visual-only",
    "ci:local": "node scripts/ci-local.mjs",
    "ci:local:all": "node scripts/ci-local.mjs --all",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e/lead-gen-smoke.spec.ts",
    "test:production-copy": "playwright test tests/e2e/production-copy.spec.ts",
    "test:visual": "playwright test tests/e2e/visual-routes.spec.ts",
    "test:e2e:production": "npm run build && PLAYWRIGHT_WEB_SERVER_COMMAND=\"npm run start\" PLAYWRIGHT_APP_ENV=production PLAYWRIGHT_ENABLE_ADMIN=false PLAYWRIGHT_BASE_URL=http://127.0.0.1:3100 PLAYWRIGHT_WEB_SERVER_URL=http://127.0.0.1:3100/uk HOST=127.0.0.1 PORT=3100 playwright test tests/e2e/production-copy.spec.ts tests/e2e/visual-routes.spec.ts",
    "images:generate": "tsx scripts/generate-images.ts",
    "images:generate:force": "tsx scripts/generate-images.ts --force",
    "quality": "npm run test && npm run build && npm run test:production-copy && npm run test:visual && npm run test:smoke",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.168.17",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-ssr-query": "^1.166.11",
    "@tanstack/react-start": "^1.167.30",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "nitro": "^3.0.260415-beta",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}
