@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Manrope:wght@300;400&display=swap');
@import "tailwindcss";

:root {
  --bg: #ffffff;
  --bg-soft: #fbfbfa;
  --text: #090909;
  --muted: rgba(9, 9, 9, 0.62);
  --line: rgba(9, 9, 9, 0.12);
  --line-strong: rgba(9, 9, 9, 0.22);
  --header-surface-opacity: 0.96;
  --home-dock-progress: 0;
  --brand-logo-ratio: 1.96;
  --chrome-surface: rgba(255, 255, 255, 0.92);
  --font-body: 'Manrope', 'Inter Variable', Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-display: 'Cormorant Garamond', Cormorant, Georgia, 'Times New Roman', serif;
  --content-width: 42rem;
  --content-width-wide: 48rem;
}

* {
  box-sizing: border-box;
}

html {
  background: var(--bg);
}

body {
  margin: 0;
  min-height: 100vh;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-weight: 400;
  text-rendering: optimizeLegibility;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  cursor: pointer;
}

:focus-visible {
  outline: 2px solid var(--text);
  outline-offset: 2px;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.skip-link {
  position: absolute;
  left: 1rem;
  top: -3rem;
  z-index: 100;
  border: 1px solid var(--line-strong);
  background: var(--bg);
  padding: 0.65rem 0.9rem;
  transition: top 180ms ease;
}

.skip-link:focus {
  top: 1rem;
}

.site-frame {
  min-height: 100vh;
  background: var(--bg);
  isolation: isolate;
  overflow: visible;
}

.site-container {
  width: min(100%, 1320px);
  margin: 0 auto;
  padding-inline: clamp(1rem, 2.4vw, 2.5rem);
  overflow: visible;
}

.site-container-wide {
  width: min(100%, 1560px);
}

.section-space {
  margin-top: clamp(4rem, 9vw, 7.5rem);
  overflow: visible;
}

.eyebrow {
  margin: 0;
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
}

.section-copy,
.editorial-copy-measure {
  max-width: var(--content-width);
}

.editorial-copy {
  margin: 0;
  max-width: var(--content-width-wide);
  font-size: clamp(0.98rem, 1.1vw, 1.08rem);
  line-height: 1.8;
  color: var(--muted);
}

.hero-title,
.section-title,
.section-subtitle,
.quote-copy,
.card-title,
.footer-tagline {
  font-family: var(--font-display);
  font-weight: 300;
  line-height: 0.98;
  letter-spacing: 0;
  color: var(--text);
  margin: 0;
}

.hero-title {
  font-size: clamp(3.4rem, 8vw, 6.6rem);
  margin-top: 0.8rem;
}

.hero-title-grand {
  font-size: clamp(4.4rem, 10.6vw, 8.6rem);
}

.hero-copy {
  margin: 1.35rem 0 0;
  max-width: var(--content-width);
  font-size: clamp(1.02rem, 1.2vw, 1.18rem);
  line-height: 1.85;
  color: var(--muted);
}

.section-title {
  font-size: clamp(2.8rem, 5.2vw, 5rem);
  margin-top: 0.9rem;
}

.section-subtitle {
  font-size: clamp(2rem, 3.4vw, 3.2rem);
  margin-top: 0.9rem;
}

.quote-copy {
  font-size: clamp(2rem, 4vw, 4.1rem);
  line-height: 1.04;
  max-width: 60rem;
  overflow-wrap: anywhere;
}

.card-title {
  font-size: clamp(1.8rem, 2.6vw, 2.6rem);
  margin-top: 0.85rem;
}

.micro-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}

.card-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  align-self: end;
  gap: 0.85rem;
  flex-wrap: wrap;
  padding-top: 0.9rem;
}

.card-action-row > .micro-tag {
  flex: 0 0 auto;
  width: auto;
}

.card-action-row > .button-primary,
.card-action-row > .button-secondary {
  flex: 0 0 auto;
}

.micro-tag,
.selector-chip {
  display: inline-flex;
  align-items: center;
  min-height: 2rem;
  border: 1px solid var(--line);
  padding: 0.32rem 0.7rem;
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text);
  background: transparent;
}

.button-primary,
.button-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  flex: 0 0 auto;
  align-self: start;
  min-height: 2.85rem;
  max-width: min(100%, 16rem);
  padding: 0.72rem 0.9rem;
  border: 1px solid var(--text);
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  line-height: 1.35;
  text-align: center;
  text-transform: uppercase;
  transition:
    background-color 180ms ease,
    color 180ms ease,
    transform 180ms ease,
    border-color 180ms ease;
}

.button-primary {
  background: var(--text);
  color: var(--bg);
}

.button-secondary {
  background: transparent;
  color: var(--text);
}

.button-primary:hover,
.button-secondary:hover,
.selector-chip:hover {
  transform: translateY(-1px);
}

.button-secondary:hover {
  background: var(--bg-soft);
}

.button-primary:hover,
.selector-chip-active {
  background: var(--text);
  color: var(--bg);
}

.button-compact {
  min-height: 2.5rem;
  padding-inline: 0.8rem;
}

.chrome-shell {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 60;
  pointer-events: none;
  color: var(--text);
}

.header-surface {
  position: absolute;
  inset: 0;
  background: var(--chrome-surface);
  opacity: var(--header-surface-opacity);
  pointer-events: none;
  border-bottom: 1px solid rgba(9, 9, 9, 0.08);
  box-shadow: 0 12px 28px rgba(9, 9, 9, 0.05);
  backdrop-filter: blur(18px) saturate(150%);
  transition: opacity 180ms ease;
}

.header-rail {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 1rem;
  min-height: 5rem;
  pointer-events: auto;
}

.header-side {
  display: flex;
  align-items: center;
}

.header-side-right {
  justify-content: flex-end;
}

.brand-mark {
  justify-self: center;
}

.header-brand-slot {
  position: relative;
  width: clamp(8.75rem, 10vw, 10.75rem);
  aspect-ratio: var(--brand-logo-ratio);
  justify-self: center;
  z-index: 1;
}

.header-brand {
  position: absolute;
  inset: 0;
  display: block;
  color: currentColor;
  will-change: transform;
}

.header-logo {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.nav-link,
.footer-link {
  position: relative;
  display: inline-block;
  width: fit-content;
  white-space: nowrap;
  font-size: 0.76rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text);
  padding-block: 0.2rem;
  transition: color 180ms ease;
}

.nav-link::after,
.footer-link::after {
  content: '';
  position: absolute;
  left: 0;
  width: 100%;
  bottom: -0.35rem;
  height: 1px;
  background: var(--text);
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 180ms ease;
}

.nav-link:hover,
.footer-link:hover,
.nav-link-active {
  color: var(--text);
}

.nav-link:hover::after,
.footer-link:hover::after,
.nav-link-active::after {
  transform: scaleX(1);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.7rem;
}

.locale-switcher {
  display: inline-flex;
  align-items: center;
  border: 1px solid currentColor;
  background: var(--chrome-surface);
  color: currentColor;
}

.locale-link {
  min-width: 2.5rem;
  padding: 0.55rem 0.72rem;
  text-align: center;
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: inherit;
  transition: background-color 180ms ease, color 180ms ease;
}

.locale-link + .locale-link {
  border-left: 1px solid currentColor;
}

.locale-link-active {
  background: var(--text);
  color: var(--bg);
}

.menu-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid currentColor;
  background: var(--chrome-surface);
  color: currentColor;
  padding: 0.72rem 0.95rem;
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  transition:
    background-color 180ms ease,
    color 180ms ease,
    border-color 180ms ease,
    transform 180ms ease;
}

.menu-toggle-inline,
.header-cta {
  pointer-events: auto;
}

.header-cta {
  background: var(--chrome-surface);
  border-color: currentColor;
  color: currentColor;
}

.header-cta:hover {
  background: var(--text);
  border-color: var(--text);
  color: var(--bg);
}

.nav-sheet-shell {
  position: relative;
  z-index: 4;
  pointer-events: auto;
  background: var(--chrome-surface);
  border-top: 1px solid rgba(9, 9, 9, 0.08);
  color: var(--text);
  display: block;
  height: 0;
  opacity: 0;
  overflow: hidden;
  pointer-events: none;
  backdrop-filter: blur(18px) saturate(150%);
  box-shadow: 0 32px 64px -12px rgba(0, 0, 0, 0.12);
}

.nav-sheet-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.25rem 1.8rem;
  padding-top: 1rem;
  padding-bottom: 1.15rem;
  align-items: start;
}

.footer-column {
  display: grid;
  gap: 0.85rem;
  align-content: start;
}

.nav-sheet-toolbar {
  display: none;
}

.mobile-nav-toolbar {
  display: none;
}

.hero-title,
.section-title,
.section-subtitle,
.quote-copy,
.card-title,
.footer-tagline {
  text-wrap: balance;
}

.editorial-copy,
.hero-copy,
.price-secondary {
  text-wrap: pretty;
}

.home-landing-shell {
  padding-top: 0;
}

.home-landing-stage {
  display: grid;
  place-items: center;
  min-height: 52dvh;
  background: var(--bg);
  padding-top: 4rem;
}

.home-stage-logo-target {
  width: min(48vw, 20rem);
  aspect-ratio: var(--brand-logo-ratio);
  visibility: hidden;
  pointer-events: none;
}

.home-landing-image-band {
  position: relative;
  width: 100%;
  height: min(66dvh, 42rem);
  overflow: clip;
}

.home-landing-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.home-copy-shell {
  margin-top: clamp(3.2rem, 7vw, 5rem);
}

.page-hero-shell {
  padding-top: 0;
}

.page-hero-media {
  position: relative;
  width: 100%;
  margin: 0;
  overflow: clip;
  height: min(58dvh, 36rem);
}

.page-hero-media-grand {
  height: min(68dvh, 42rem);
}

.page-hero-image,
.compact-intro-image,
.detail-hero-image,
.editorial-card-image,
.collection-frame-image,
.editorial-photo-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-lockup {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  padding: 2rem;
}

.hero-lockup-image {
  width: min(62vw, 31rem);
  opacity: 0.95;
}

.page-hero-caption {
  position: absolute;
  left: 1.25rem;
  bottom: 1.1rem;
  border: 1px solid rgba(255, 255, 255, 0.28);
  background: rgba(9, 9, 9, 0.54);
  color: var(--bg);
  padding: 0.45rem 0.65rem;
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.page-hero-copy-wrap {
  display: grid;
  gap: 0.9rem;
  padding-top: 1.6rem;
  padding-bottom: 0.25rem;
}

.page-hero-copy-wrap-grand {
  padding-top: 1.8rem;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-top: 1.6rem;
}

.compact-intro-shell {
  padding-top: 0;
}

.compact-intro-media {
  width: 100%;
  margin: 0;
  height: min(54dvh, 32rem);
  overflow: clip;
}

.compact-intro-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
  padding-top: 2rem;
}

.compact-intro-aside {
  display: grid;
  gap: 1rem;
  padding-top: 0.3rem;
  border-top: 1px solid var(--line);
}

.section-head {
  display: grid;
  gap: 0.9rem;
  margin-bottom: 2rem;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.25rem;
  border-top: 1px solid var(--line);
}

.stat-block {
  padding-top: 1.2rem;
  border-right: 1px solid var(--line);
  padding-right: 1.2rem;
}

.stat-block:last-child {
  border-right: 0;
  padding-right: 0;
}

.stat-value {
  margin: 0.95rem 0 0.5rem;
  font-family: var(--font-display);
  font-size: clamp(2.7rem, 4.2vw, 4.6rem);
  line-height: 0.96;
  letter-spacing: 0;
}

.editorial-split {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
  gap: clamp(2rem, 6vw, 6rem);
}

.editorial-split-main,
.editorial-split-quote,
.detail-section,
.editorial-panel {
  border-top: 1px solid var(--line);
  padding-top: 1.1rem;
}

.editorial-split-main {
  display: grid;
  gap: 1rem;
}

.editorial-split-quote {
  display: grid;
  align-content: start;
  gap: 1rem;
}

.editorial-list {
  display: grid;
  gap: 1rem;
  margin: 1.2rem 0 0;
  padding: 0;
  list-style: none;
}

.editorial-list-tight {
  gap: 0.7rem;
}

.editorial-list-item {
  display: grid;
  grid-template-columns: 2.4rem minmax(0, 1fr);
  gap: 0.8rem;
  align-items: start;
  padding-top: 0.75rem;
  border-top: 1px solid var(--line);
  font-size: 0.98rem;
  line-height: 1.8;
}

.list-index {
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
}

.offer-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 2rem 1.5rem;
}

.offer-grid-third {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.editorial-card {
  display: grid;
  gap: 1rem;
}

.editorial-card-media {
  position: relative;
  aspect-ratio: 4 / 5;
  max-height: min(70dvh, 34rem);
  overflow: clip;
}

.editorial-card-compact .editorial-card-media {
  aspect-ratio: 4 / 4.8;
  max-height: min(58dvh, 24rem);
}

.editorial-card-tag {
  position: absolute;
  left: 1rem;
  bottom: 1rem;
  background: rgba(255, 255, 255, 0.92);
}

.editorial-card-body {
  display: grid;
  gap: 0.9rem;
}

.editorial-card-head,
.price-row,
.collection-story,
.detail-hero-grid,
.editorial-two-column {
  display: grid;
  gap: 0.8rem;
}

.editorial-card-head {
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: start;
}

.editorial-inline-meta,
.detail-pair {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem 1rem;
  justify-content: flex-end;
  font-size: 0.78rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

.price-row {
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: end;
  padding-top: 0.9rem;
  border-top: 1px solid var(--line);
}

.price-value {
  margin: 0.4rem 0 0;
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 2.5vw, 2.5rem);
  line-height: 0.98;
  letter-spacing: 0;
}

.price-secondary {
  margin: 0.35rem 0 0;
  font-size: 0.95rem;
  line-height: 1.6;
  color: var(--muted);
}

.detail-hero-shell {
  padding-top: 0;
}

.detail-hero-media {
  width: 100%;
  margin: 0;
  height: min(62dvh, 38rem);
  overflow: clip;
}

.detail-hero-grid,
.collection-story,
.editorial-two-column {
  grid-template-columns: minmax(0, 1.14fr) minmax(15rem, 0.86fr);
  padding-top: 1.4rem;
}

.atelier-feature {
  display: grid;
  grid-template-columns: minmax(0, 1.16fr) minmax(19rem, 0.84fr);
  gap: 1.2rem;
  align-items: start;
}

.atelier-feature-copy {
  gap: 0.9rem;
}

.atelier-feature-text {
  max-width: 34rem;
}

.atelier-feature-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.7rem;
  margin-top: 0.3rem;
}

.atelier-feature-cta {
  margin-left: 0.25rem;
}

.atelier-feature-aside {
  display: grid;
  gap: 0.8rem;
}

.atelier-feature-image {
  position: relative;
  height: min(40dvh, 21rem);
  overflow: clip;
}

.atelier-feature-secondary {
  gap: 0.65rem;
}

.detail-hero-aside {
  display: grid;
  gap: 1rem;
  align-content: start;
  border-top: 1px solid var(--line);
  padding-top: 0.8rem;
}

.detail-sections-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.8rem 2rem;
}

.detail-stack {
  display: grid;
  gap: 0;
  margin: 0;
  padding: 0;
  list-style: none;
}

.detail-line-item {
  display: grid;
  gap: 0.35rem;
  padding: 0.9rem 0;
  border-top: 1px solid var(--line);
}

.detail-line-item-note {
  padding-block: 0.85rem;
}

.detail-line-title {
  margin: 0;
  font-size: 1.02rem;
  font-weight: 400;
  color: var(--text);
}

.quote-band {
  display: grid;
  gap: 1rem;
  border-top: 1px solid var(--line);
  padding-top: 1.2rem;
}

.quote-band-compact .quote-copy {
  max-width: 46rem;
  font-size: clamp(1.8rem, 3.2vw, 3rem);
}

.collection-gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.collection-frame {
  position: relative;
  height: min(52dvh, 28rem);
  overflow: clip;
}

.collection-frame-large {
  grid-column: 1 / -1;
  height: min(66dvh, 40rem);
}

.collection-frame-caption {
  position: absolute;
  left: 1rem;
  bottom: 1rem;
  background: rgba(255, 255, 255, 0.92);
  padding: 0.45rem 0.65rem;
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.collection-story-side {
  display: grid;
  align-content: start;
  gap: 1rem;
  border-top: 1px solid var(--line);
  padding-top: 1rem;
}

.editorial-panel,
.editorial-panel-compact,
.editorial-photo-panel {
  display: grid;
  gap: 0.65rem;
}

.editorial-panel-compact {
  padding-top: 0.6rem;
}

.editorial-side-stack {
  display: grid;
  gap: 0.8rem;
}

.editorial-photo-panel {
  height: min(38dvh, 21rem);
  overflow: clip;
}

.editorial-form {
  display: grid;
  gap: 1.25rem;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.form-grid-setup {
  grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
}

.form-cluster {
  display: grid;
  gap: 1rem;
}

.field {
  display: grid;
  gap: 0.6rem;
}

.field > span {
  font-size: 0.74rem;
  font-weight: 400;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--muted);
}

.field input,
.field select,
.field textarea {
  width: 100%;
  border: 0;
  border-bottom: 1px solid var(--line-strong);
  background: transparent;
  padding: 0.85rem 0 0.75rem;
  color: var(--text);
  border-radius: 0;
  appearance: none;
}

.field textarea {
  resize: vertical;
  min-height: 7rem;
}

.field input::placeholder,
.field textarea::placeholder {
  color: rgba(9, 9, 9, 0.38);
}

.next-step-panel {
  display: grid;
  gap: 1rem;
  padding-top: 1rem;
  border-top: 1px solid var(--line);
}

.booking-price-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.85rem;
}

.metric-card {
  display: grid;
  gap: 0.4rem;
  padding-top: 0.8rem;
  border-top: 1px solid var(--line);
}

.metric-value {
  margin: 0;
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 2.2vw, 2.2rem);
  line-height: 1;
}

.form-status {
  margin: 0;
  padding-top: 0.9rem;
  border-top: 1px solid var(--line);
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--muted);
}

.site-footer {
  margin-top: clamp(5rem, 10vw, 8rem);
  border-top: 1px solid var(--line);
}

.footer-logo-band {
  width: 100%;
  margin-top: 0;
  padding-top: 1rem;
}

.footer-logo-band-image {
  width: 100%;
  height: auto;
}

.footer-column {
  display: grid;
  align-content: start;
  gap: clamp(1.2rem, 3.5vw, 0.85rem);
}

.route-curtain {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: grid;
  place-items: center;
  background: var(--bg);
  transform: translateY(-110%);
  overflow: hidden;
  pointer-events: none;
  opacity: 0;
  will-change: transform, opacity;
}

.route-curtain::before {
  content: '';
  position: absolute;
  inset: clamp(1rem, 2.6vw, 2.6rem);
  border: 1px solid var(--line);
  opacity: 0.64;
  pointer-events: none;
}

.route-curtain-logo {
  position: relative;
  z-index: 2;
  width: min(68vw, 19rem);
  height: auto;
  opacity: 0;
  transform: translateY(-1.125rem) scale(0.94);
  will-change: transform, opacity;
}

.route-curtain-rule {
  position: absolute;
  left: 50%;
  top: calc(50% + clamp(3.7rem, 7vw, 5.3rem));
  z-index: 1;
  width: min(62vw, 34rem);
  height: 1px;
  background: var(--text);
  opacity: 0;
  transform: translateX(-50%) scaleX(0);
  transform-origin: center;
  will-change: transform, opacity;
}

.footer-legal {
  padding-top: 0.7rem;
  padding-bottom: 0.9rem;
}

.footer-legal-copy {
  margin: 0;
  font-size: 0.66rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
}

@media (max-width: 1180px) {
  .header-side-right {
    display: none;
  }

  .nav-sheet-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .nav-sheet-toolbar {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    grid-column: 1 / -1;
  }

  .offer-grid-third {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 960px) {
  .nav-sheet-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.5rem 1.5rem;
  }
  
  .nav-sheet-grid .footer-link,
  .nav-sheet-grid .nav-link {
    font-size: 0.95rem;
    padding-block: 0.4rem;
  }
  
  .nav-sheet-grid .eyebrow {
    font-size: 0.8rem;
    margin-bottom: 0.4rem;
  }

  .stats-grid,
  .detail-sections-grid,
  .offer-grid,
  .offer-grid-third,
  .collection-gallery-grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .form-grid,
  .form-grid-setup,
  .booking-price-grid {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .stat-block {
    border-right: 0;
    padding-right: 0;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1.25rem;
  }

  .stat-block:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .editorial-card-head,
  .price-row {
    grid-template-columns: 1fr;
  }

  .card-action-row {
    align-items: flex-start;
  }

  .editorial-inline-meta,
}

@media (max-width: 640px) {
  .header-rail {
    min-height: 4.4rem;
  }

  .hero-title-grand {
    font-size: clamp(3.1rem, 14vw, 4rem);
    overflow-wrap: anywhere;
  }

  .header-brand-slot {
    width: 7.9rem;
  }

  .home-landing-stage {
    min-height: 48dvh;
    padding-top: 3rem;
  }

  .home-stage-logo-target {
    width: min(70vw, 16rem);
  }

  .atelier-feature-meta {
    gap: 0.6rem;
  }

  .atelier-feature-cta {
    margin-left: 0;
  }

  .page-hero-media-grand,
  .detail-hero-media,
  .compact-intro-media,
  .home-landing-image-band {
    height: min(52dvh, 25rem);
  }

  .hero-lockup-image {
    width: min(74vw, 18rem);
  }

  .quote-copy {
    line-height: 1.08;
  }

  .nav-sheet-shell {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(24px) saturate(150%);
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
  }

  .nav-sheet-grid {
    grid-template-columns: 1fr;
    gap: 3.5rem 1.5rem;
    padding-top: 2.5rem;
    padding-bottom: 5rem;
    min-height: calc(100dvh - 4.4rem);
    align-content: start;
  }

  .nav-sheet-grid .footer-link,
  .nav-sheet-grid .nav-link {
    font-size: 1.25rem;
    padding-block: 0.5rem;
    letter-spacing: 0.12em;
    color: var(--text);
  }

  .nav-sheet-grid .eyebrow {
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    color: var(--text);
    opacity: 0.6;
  }
}
